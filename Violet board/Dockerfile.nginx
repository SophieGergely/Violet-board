# Copies /var/www/public from the PHP-FPM image so nginx can serve
# static files (CSS, JS, images) without a bind mount in the cloud setup.
# PHP requests are forwarded to the violetboard-app container via fastcgi.

ARG APP_IMAGE
FROM ${APP_IMAGE} AS source

FROM nginx:alpine
COPY --from=source /var/www/public /var/www/public
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
